<Window x:Class="FastFoodOrderSystem.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profil" Height="400" Width="480" WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Profil používateľa" FontSize="18" FontWeight="Bold"/>

        <StackPanel Grid.Row="1" Margin="0,10">
            <TextBlock Text="Meno: Demo Používateľ"/>
            <TextBlock Text="Email: demo@primeplate.app"/>
            <StackPanel Orientation="Horizontal" Margin="0,10">
                <TextBlock Text="Vernostné body: " FontWeight="Bold"/>
                <TextBlock x:Name="PointsText" FontWeight="Bold"/>
            </StackPanel>

            <TextBlock Text="Nedávne objednávky:" FontWeight="Bold" Margin="0,10,0,5"/>
            <ListBox x:Name="OrdersList" Height="160"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Zavrieť" Width="90" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>