<Window x:Class="FastFoodOrderSystem.SmtpSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SMTP Nastavenia" Height="350" Width="420" WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="SMTP Nastavenia" FontSize="18" FontWeight="Bold"/>

        <StackPanel Grid.Row="1" Margin="0,10">
            <TextBlock Text="SMTP server"/>
            <TextBox x:Name="SmtpHost" />
            <TextBlock Text="Port" Margin="0,8,0,0"/>
            <TextBox x:Name="SmtpPort" />
            <TextBlock Text="Odosielateľ (e-mail)" Margin="0,8,0,0"/>
            <TextBox x:Name="SenderEmail" />
            <TextBlock Text="Heslo od sendra (app password)" Margin="0,8,0,0"/>
            <PasswordBox x:Name="SenderPassword" />
            <!-- SendGrid options removed -->
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Testovať" Width="90" Margin="0,0,10,0" Click="Test_Click"/>
            <Button Content="Zrušiť" Width="90" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="Uložiť" Width="90" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>